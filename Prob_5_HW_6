import numpy as np

k = 300
q = 100
m = 2

def f(x):
    return (k/m) * x + (q/m) * (x**3)

a = 0
b = 0.4
n = 16  
h = (b - a) / n
x = np.linspace(a, b, n + 1)
y = f(x)

# Simpson's
integral = (h / 3) * (y[0] + 4 * np.sum(y[1:-1:2]) + 2 * np.sum(y[2:-1:2]) + y[-1])

# Need to multiply by 2 and find square root for final calc
v0 = np.sqrt(2 * integral)

print(f"Integral value: {integral:.3f}")
print(f"Final Velocity v0: {v0:.3f} m/s")
